      "pluginVersion": "12.3.1",
      "targets": [
        {
          "editorType": "sql",
          "format": 1,
          "meta": {
            "builderOptions": {
              "columns": [],
              "database": "",
              "limit": 1000,
              "mode": "list",
              "queryType": "table",
              "table": ""
            }
          },
          "pluginVersion": "4.18.0",
          "queryType": "table",
          "rawSql": "SELECT \r\n    src_ip,\r\n    arrayStringConcat(arrayMap(x -> toString(x), groupUniqArray(dst_port)), ', ') AS ports,\r\n    uniq(dst_ip) AS targets,\r\n    count() AS events,\r\n    multiIf(\r\n        has(groupUniqArray(dst_port), 445) OR has(groupUniqArray(dst_port), 139), 80,\r\n        has(groupUniqArray(dst_port), 3389) OR has(groupUniqArray(dst_port), 23), 70,\r\n        has(groupUniqArray(dst_port), 22), 40,\r\n        uniq(dst_port) >= 20, 50,\r\n        0\r\n    ) AS risk_score\r\nFROM sentinel.firewall_events\r\nWHERE $__timeFilter(event_time)\r\n  AND match(src_ip, '$src_ip')\r\nGROUP BY src_ip\r\nHAVING risk_score >= 40\r\nORDER BY risk_score DESC\r\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Risk Engine",
      "type": "table"
    },
