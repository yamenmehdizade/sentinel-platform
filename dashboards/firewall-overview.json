          "pluginVersion": "4.18.0",
          "queryType": "table",
          "rawSql": "SELECT toString(dst_port) AS port, count() AS hits\r\nFROM sentinel.firewall_events\r\nWHERE $__timeFilter(event_time)\r\n  AND match(src_ip, '$src_ip')\r\nGROUP BY dst_port\r\nORDER BY hits DESC\r\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Most Targeted Ports",
      "type": "barchart"
